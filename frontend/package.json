{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:prod": "ng build --configuration production --base-href ./",
    "electron": "electron .",
    "electron:dev": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.11",
    "better-sqlite3": "^12.9.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.jens.redminedashboard",
    "productName": "Redmine Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/frontend/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "redmine_proxy.py",
        "to": "redmine_proxy.py"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
